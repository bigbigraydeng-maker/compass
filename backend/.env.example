# 环境配置
ENV=local  # local, supabase, mock

# 数据库配置 (local)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/compass

# 数据库配置 (supabase) - 生产环境使用
# DATABASE_URL=postgresql://postgres:your_password@db.your_project.supabase.co:5432/postgres

# Google Maps API 配置
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# 应用配置
APP_NAME=Compass MVP
APP_VERSION=1.0.0

# CORS 配置（生产环境请修改为具体域名）
CORS_ORIGINS=*
